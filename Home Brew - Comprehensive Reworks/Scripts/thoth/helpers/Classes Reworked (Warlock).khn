local __util = require 'larian.util'

function IsEldritchBlastVariant()
    return SpellId('Projectile_EldritchBlast') | SpellId('Projectile_EldritchBlast_Penumbral_Necrotic') | SpellId('Projectile_EldritchBlast_Penumbral_Radiant')
    | SpellId('Zone_EldritchLance') | SpellId('Zone_EldritchLance_2') | SpellId('Zone_EldritchLance_3')
    | SpellId('Zone_EldritchLance_4') | SpellId('Zone_EldritchLance_5') | SpellId('Zone_EldritchLance_6')
    | SpellId('Projectile_EldritchBlastStrike') 
end
